# Backend environment — copy to .env and adjust locally (gitignored).
# AD-8: Secrets server-side only — never commit this file with real values.

# AI provider: mock (default, CI/tests) | gemini (requires key + model)
# APP_AI_ENABLED=true
# APP_AI_PROVIDER=mock
# APP_AI_MODEL=local-mock
# For gemini:
# APP_AI_PROVIDER=gemini
# APP_AI_MODEL=gemini-2.5-flash
# APP_AI_TIMEOUT_MS=8000

# Gemini API key — ONLY via environment / this local file, never in code or frontend
# GEMINI_API_KEY=

# PostgreSQL (required since Story 3.1 — Flyway/JPA)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cgi_kpi_dashboard
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=

# Initial admin (Story 11.2) — only used when no app_user exists yet; never commit real values
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_PASSWORD=
