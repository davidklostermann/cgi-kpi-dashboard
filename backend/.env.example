# Backend environment — copy to .env and adjust locally (gitignored).
# AD-8: Secrets server-side only — never commit this file with real values.

# Gemini API (required once AI features are implemented)
# GEMINI_API_KEY=

# PostgreSQL (required since Story 3.1 — Flyway/JPA)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/cgi_kpi_dashboard
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=
