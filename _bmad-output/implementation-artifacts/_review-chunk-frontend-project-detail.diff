+        assessment:
+          delta === 0
+            ? 'Stabil'
+            : delta > 0
+              ? 'Verschlechterung'
+              : 'Verbesserung',
+        tone: delta === 0 ? 'unchanged' : delta > 0 ? 'worsened' : 'improved',
+        icon: delta === 0 ? 'ÔåÆ' : delta > 0 ? 'Ôåæ' : 'Ôåô',
+      });
+    }
+
+    return cards;
+  }
+
+  private statusTone(
+    previous: string | null | undefined,
+    current: string | null | undefined,
+  ): ComparisonTone {
