+      });
+    }
+
+    if (data.scheduleDeviationDeltaDays != null) {
+      const delta = data.scheduleDeviationDeltaDays;
+      const abs = Math.abs(delta).toLocaleString('de-DE');
+      cards.push({
+        id: 'schedule',
+        metric: 'Termin',
+        change:
+          delta === 0
+            ? 'Unver├ñndert'
+            : delta > 0
+              ? `+${abs} Tage Abweichung`
+              : `ÔêÆ${abs} Tage Abweichung`,
+        assessment:
+          delta === 0
+            ? 'Stabil'
+            : delta > 0
+              ? 'Verschlechterung'
+              : 'Verbesserung',
+        tone: delta === 0 ? 'unchanged' : delta > 0 ? 'worsened' : 'improved',
+        icon: delta === 0 ? 'ÔåÆ' : delta > 0 ? 'Ôåô' : 'Ôåæ',
+      });
+    }
+
+    if (data.previousStatusLabel && data.currentStatusLabel) {
+      const tone = this.statusTone(data.previousStatus, data.currentStatus);
+      cards.push({
+        id: 'status',
+        metric: 'Status',
+        change:
+          data.previousStatusLabel === data.currentStatusLabel
+            ? data.currentStatusLabel
+            : `${data.previousStatusLabel} ÔåÆ ${data.currentStatusLabel}`,
+        assessment:
+          tone === 'unchanged'
+            ? 'Unver├ñndert'
+            : tone === 'improved'
+              ? 'Verbesserung'
+              : tone === 'worsened'
+                ? 'Verschlechterung'
+                : 'Statuswechsel',
+        tone,
+        icon: tone === 'improved' ? 'Ôåæ' : tone === 'worsened' ? 'Ôåô' : 'ÔåÆ',
+      });
+    }
+
+    if (data.openRiskCountDelta != null) {
+      const delta = data.openRiskCountDelta;
+      const abs = Math.abs(delta).toLocaleString('de-DE');
+      cards.push({
+        id: 'risks',
+        metric: 'Risiken',
+        change:
+          delta === 0
+            ? 'Unver├ñndert'
+            : delta > 0
+              ? `+${abs} offene Risiken`
